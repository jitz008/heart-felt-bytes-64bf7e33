rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for user subcollections
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Tasks security boundaries
    match /users/{userId}/tasks/{taskId} {
      allow read, write: if isOwner(userId);
    }

    // User Lists security boundaries
    match /users/{userId}/lists/{listId} {
      allow read, write: if isOwner(userId);
    }

    // User Habits security boundaries
    match /users/{userId}/habits/{habitId} {
      allow read, write: if isOwner(userId);
    }
  }
}
